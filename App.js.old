 *  ✓ Filtre chips et layer chips ne se superposent plus jamais
 *
 * CORRECTIONS v2 (conservées) :
 *  ✓ handleMapPress : extraction immédiate de coordinate avant setState async
 *  ✓ Modals : structure flex correcte, maxHeight, ScrollView bornée
 *  ✓ WeatherContent : daily sécurisé avec valeurs par défaut
 *  ✓ analyzeRisks : déstructuration sécurisée
 */

import React, { useState, useEffect, useRef } from 'react';
import {
  View, Text, StyleSheet, Alert, TouchableOpacity, TextInput,
  Modal, ScrollView, ActivityIndicator, StatusBar, Linking,
  Animated, Vibration, Platform, KeyboardAvoidingView,
} from 'react-native';
import MapView, { Polygon, Marker, Polyline } from 'react-native-maps';
import * as SQLite from 'expo-sqlite';
import * as turf from '@turf/turf';
