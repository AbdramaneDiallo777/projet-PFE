{
  "name": "agroconnect-africa",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "node ./scripts/start-expo-wifi.mjs",
    "start:clear": "node ./scripts/start-expo-wifi.mjs --clear",
    "start:localhost": "expo start --localhost",
    "start:usb-android": "expo start --localhost",
    "adb:reverse": "adb reverse tcp:8081 tcp:8081 && adb reverse tcp:8000 tcp:8000",
    "start:tunnel": "node ./scripts/check-packager-env.mjs && expo start --localhost",
    "tunnel:metro": "node ./scripts/tunnel-metro.mjs",
    "tunnel:dev": "node ./scripts/tunnel-dev.mjs",
    "tunnel:api": "node ./scripts/tunnel-api.mjs",
    "dev:proxy": "node ./scripts/dev-public-proxy.mjs",
    "tunnel:single": "node ./scripts/tunnel-single.mjs",
    "api": "python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload",
    "api:py": "py -m uvicorn backend.main:app --host 0.0.0.0 --port 8000 --reload",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "api:stack": "powershell -ExecutionPolicy Bypass -File ./scripts/start-backend-stack.ps1",
    "ml": "powershell -ExecutionPolicy Bypass -File ./scripts/start-flask-ml.ps1",
    "ml:build-model": "powershell -ExecutionPolicy Bypass -File ./scripts/build-ml-model.ps1",
    "env:lan": "node ./scripts/show-lan-ip.mjs",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "2.0.2",
    "@turf/turf": "^7.3.4",
    "axios": "^1.15.0",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "lucide-react-native": "^0.562.0",
    "moti": "^0.30.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-web-maps": "^0.3.0",
    "react-native-worklets": "0.5.1",
    "tslib": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@ngrok/ngrok": "^1.7.0",
    "@react-native-community/cli": "^20.1.0",
    "@types/react": "~19.1.0",
    "dotenv": "^17.4.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "http-proxy": "^1.18.1",
    "typescript": "~5.9.2"
  },
  "private": true
